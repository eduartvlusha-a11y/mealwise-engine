{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "main",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "tsc",
    "assets": [
      {
        "include": "ai/prompts/*.txt",
        "outDir": "dist/src/ai/prompts",
        "watchAssets": true
      }
    ]
  }
}
